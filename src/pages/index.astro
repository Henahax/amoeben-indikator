---
import Layout from "../layouts/Layout.astro";
import ScaleElement from "../components/ScaleElement.astro";
import HistoryElement from "../components/HistoryElement.astro";

import scale from "../assets/scale.json";

let currentValue = 0;

import { db, Entry, desc } from "astro:db";

const entries = await db
  .select()
  .from(Entry)
  .orderBy(desc(Entry.date))
  .limit(5);

currentValue = getValue(entries);

function getValue(entries: any) {
  let temp = 0;

  entries.forEach((entry: any) => {
    temp += entry.value;
  });

  return temp / entries.length;
}
---

<Layout>
  
    <h1 class="text-4xl font-bold">Amöben-Indikator</h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="flex">
        <ul class="steps steps-vertical mx-auto">
          {
            scale
              .toReversed()
              .map((item) => (
                <ScaleElement
                  description={item.name}
                  minValue={item.value}
                  value={currentValue}
                  icon={item.icon}
                />
              ))
          }
        </ul>
      </div>
      <div class="flex flex-col gap-4">
        <h2 class="text-xl">Letzte Einträge:</h2>
        <div class="entries">
          {
            entries.map(({ name, value, date, description }) => (
              <HistoryElement
                name={name}
                description={description}
                value={value}
                date={date}
              />
            ))
          }
        </div>
      </div>
    </div>

    <a class="btn btn-primary" href="/new">Neuer Eintrag</a>
</Layout>

<style>
  .entries {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem 4rem;
  }
</style>
