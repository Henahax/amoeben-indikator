---
import Layout from "../layouts/Layout.astro";
import ScaleElement from "../components/ScaleElement.astro";
import HistoryElement from "../components/HistoryElement.astro";

import scale from "../assets/scale.json";

let value = 60;
---

<Layout>
  <app class="flex flex-col items-center gap-8">
    <h1 class="text-4xl">Amöben-Indikator</h1>

    <div class="flex flex-wrap justify-center gap-16">
      <div class="p-8">
        <ul class="steps steps-vertical mx-auto">
          {
            scale.map((item) => (
              <ScaleElement
                description={item.name}
                minValue={item.value}
                value={value}
                icon={item.icon}
              />
            ))
          }
        </ul>
      </div>
      <div class="p-8 flex flex-col gap-4">
        <h2 class="text-2xl">Letzte Einträge:</h2>
        <div class="grid grid-cols-3 gap-8 items-center">
          <HistoryElement
            name="TobiasH"
            description="Kaffee verschüttet"
            value={40}
          />
          <HistoryElement
            name="RainerG"
            description="Video veröffentlicht"
            value={100}
          />
        </div>
      </div>
    </div>

	<button class="btn btn-primary" onclick="my_modal_5.showModal()">Neuer Eintrag</button>
	<dialog id="my_modal_5" class="modal modal-bottom sm:modal-middle">
	  <div class="modal-box">
		<h3 class="text-lg font-bold">Neuer Eintrag</h3>
		<p>Bitte vollständig ausfüllen</p>
		<div class="modal-action">
		  <form method="dialog" class="w-full flex flex-col gap-4">
			<label class="input input-bordered flex items-center gap-2">
				<i class="fa-solid fa-user"></i>
				<input type="text" class="grow" placeholder="Name" />
			  </label>
			  <label class="form-control w-full">
				<select class="select select-bordered w-full">
				  {
					  scale.map((item) => (
						<option value={item.value}>{item.name}</option>
					  ))
					}
				</select>
			  </label>
			  <label class="input input-bordered flex items-center gap-2">
				<input type="text" class="grow" placeholder="Kommentar" />
			  </label>
			  <label class="input input-bordered flex items-center gap-2">
				<i class="fa-solid fa-key"></i>
				<input type="password" class="grow" placeholder="Passwort" />
			  </label>
			<button class="btn btn-primary">Absenden</button>
		  </form>
		</div>
	  </div>
	</dialog>

  </app>
</Layout>
