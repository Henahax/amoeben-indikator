---
import scale from "../assets/scale.json";
import { type Entry } from '../models/types';
interface Props {
  entry: Entry;
}
const { entry } = Astro.props;
---

<div class="flex flex-col justify-center">
  <div>{name}</div>
  <div class="text-xs opacity-50">{entry.date}</div>
</div>
<div class="flex flex-row items-center gap-2 text-xl">
  {
    scale.map(
      (item) =>
        item.value === entry.value && (
            <i class={item.icon + " w-6"} />
            <div>{item.name}</div>
        )
    )
  }
</div>
<div class="flex items-center text-sm">{entry.description}</div>
