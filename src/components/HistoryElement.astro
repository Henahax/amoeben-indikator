---
import scale from "../assets/scale.json";
interface Props {
  name: string,
  value: number,
  description: string,
  date: string
}
const { name, value, description, date } = Astro.props;
---

<div class="flex flex-col justify-center">
  <div>{name}</div>
  <div class="text-xs opacity-50">{date}</div>
</div>
<div class="flex flex-row items-center gap-2 text-xl">
  {
    scale.map(
      (item) =>
        item.value === value && (
            <i class={item.icon + " w-6"} />
            <div>{item.name}</div>
        )
    )
  }
</div>
<div class="flex items-center text-sm">{description}</div>
